# Copy to .env and edit — never commit .env to git

# Random hex string · this is the API key clients present to LiteLLM
# Generate with: openssl rand -hex 32
LITELLM_MASTER_KEY=change-me-to-a-random-hex-string

# Optional · override compressor default ratio (0.0 = maximum compression, 1.0 = no compression)
# COMPRESS_RATIO=0.5
